# Copy this file to .env before running Docker Compose.
# Do not commit real provider API keys or production secrets.

POSTGRES_DB=echat
POSTGRES_USER=echat
POSTGRES_PASSWORD=change-me-local-postgres
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_PASSWORD=

SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=default
CONTEXT_EMBEDDING_DIMENSION=1536
API_KEY_ENCRYPTION_SECRET=change-this-local-32-byte-secret-0001
ADMIN_TOKEN=dev-admin-token
ADMIN_ACTOR_ID=local-admin
ADMIN_DISPLAY_NAME=Local Admin
ADMIN_TENANT_ID=default
ADMIN_ROLES=ADMIN,AUDITOR
ADMIN_COOKIE_SECURE=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Optional defaults used by backend seed data or provider tests.
LLM_PROVIDER=openai-compatible
LLM_MODEL=gpt-4.1-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# Browser-facing URLs. For local Docker Compose this must be a URL reachable
# from your browser, not the internal Docker service name.
VITE_API_BASE_URL=http://localhost:8080
VITE_CHATBOT_ID=1
VITE_CHATBOT_NAME=eChat Assistant
